# SAQR Demo Environment
# Keeps the current client-demo experience intact.

SAQR_RUNTIME_MODE=demo
SAQR_LOG_LEVEL=info
SAQR_LOG_INCLUDE_STACKS=false
SAQR_AUDIT_LOG_ENABLED=true

# API
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change_me_in_demo
AUTH_ENABLED=false
AUTH_JWT_ISSUER=saqr
AUTH_JWT_AUDIENCE=saqr-api
AUTH_JWT_LEEWAY_SECONDS=30
PUBLIC_SOURCES_HEARTBEAT_ENABLED=true
SAQR_REGULATORY_AUTHORITIES=SAMA,SDAIA,ZATCA,SFDA,MOH,MOMAH,MHRSD

# Shadow DB placeholders
SHADOW_DB_HOST=localhost
SHADOW_DB_PORT=5432
SHADOW_DB_NAME=saqr_shadow
SHADOW_DB_USER=saqr
SHADOW_DB_PASSWORD=change_me_in_demo

# Evidence Vault
NTP_SERVER=pool.ntp.org
NTP_TIMEOUT_MS=3000
EVIDENCE_HASH_ALGORITHM=sha256
EVIDENCE_VAULT_ALLOW_SYSTEM_CLOCK_FALLBACK=true
EVIDENCE_VAULT_VALIDATE_DB_ON_STARTUP=true
EVIDENCE_VAULT_VALIDATE_NTP_ON_STARTUP=false
EVIDENCE_VAULT_TOPICS=saqr.cdc.client_banking.public.consumer_disclosures,saqr.cdc.client_banking.public.fee_schedule,saqr.cdc.client_banking.public.cooling_off_periods,saqr.cdc.client_banking.public.branch_compliance
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=saqr-evidence-vault
KAFKA_GROUP_ID=saqr-vault-consumer

# CV Watchman
VMS_TYPE=demo
CV_SCAN_INTERVAL=5000
CV_VALIDATE_DB_ON_STARTUP=false
CV_VMS_HOST=localhost
CV_VMS_PORT=443
CV_VMS_USERNAME=demo
CV_VMS_PASSWORD=change_me_in_demo
CV_VMS_USE_TLS=true
CV_VMS_APP_ID=SAQR-Watchman
CV_VMS_MAX_FPS=1

# Sentinel
SENTINEL_MODE=demo
SENTINEL_CRON=*/15 * * * *
SENTINEL_VALIDATE_DB_ON_STARTUP=false
SENTINEL_BROWSER_HEADLESS=true

# NLP
NLP_BOOT_MODE=demo-ingest
NLP_VALIDATE_DB_ON_STARTUP=false

# UI
NEXT_PUBLIC_API_URL=http://localhost:3001
SAQR_UI_RUNTIME_CONFIG=apps/shield-ui/runtime-config.demo.js
