# SAQR Production-Ready Handoff Environment
# Interface-ready profile for the delivery team.
# No live infrastructure is assumed in this repository.

SAQR_RUNTIME_MODE=production
SAQR_LOG_LEVEL=info
SAQR_LOG_INCLUDE_STACKS=false
SAQR_AUDIT_LOG_ENABLED=true

# API
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=replace_in_delivery
AUTH_ENABLED=true
AUTH_JWT_ISSUER=saqr
AUTH_JWT_AUDIENCE=saqr-api
AUTH_JWT_LEEWAY_SECONDS=30
PUBLIC_SOURCES_HEARTBEAT_ENABLED=false
SAQR_REGULATORY_AUTHORITIES=SAMA,SDAIA

# Shadow DB placeholders
SHADOW_DB_HOST=replace-by-delivery-team
SHADOW_DB_PORT=5432
SHADOW_DB_NAME=saqr_shadow
SHADOW_DB_USER=replace-by-delivery-team
SHADOW_DB_PASSWORD=replace-by-delivery-team

# Evidence Vault
NTP_SERVER=pool.ntp.org
NTP_TIMEOUT_MS=3000
EVIDENCE_HASH_ALGORITHM=sha256
EVIDENCE_VAULT_ALLOW_SYSTEM_CLOCK_FALLBACK=false
EVIDENCE_VAULT_VALIDATE_DB_ON_STARTUP=true
EVIDENCE_VAULT_VALIDATE_NTP_ON_STARTUP=true
EVIDENCE_VAULT_TOPICS=saqr.cdc.client_banking.public.consumer_disclosures,saqr.cdc.client_banking.public.fee_schedule,saqr.cdc.client_banking.public.cooling_off_periods,saqr.cdc.client_banking.public.branch_compliance
KAFKA_BOOTSTRAP_SERVERS=replace-by-delivery-team
KAFKA_CLIENT_ID=saqr-evidence-vault
KAFKA_GROUP_ID=saqr-vault-consumer

# CV Watchman placeholders
VMS_TYPE=milestone
CV_SCAN_INTERVAL=5000
CV_VALIDATE_DB_ON_STARTUP=true
CV_VMS_HOST=replace-by-delivery-team
CV_VMS_PORT=443
CV_VMS_USERNAME=replace-by-delivery-team
CV_VMS_PASSWORD=replace-by-delivery-team
CV_VMS_USE_TLS=true
CV_VMS_APP_ID=SAQR-Watchman
CV_VMS_MAX_FPS=1

# Sentinel placeholders
SENTINEL_MODE=live
SENTINEL_CRON=*/15 * * * *
SENTINEL_VALIDATE_DB_ON_STARTUP=true
SENTINEL_BROWSER_HEADLESS=true

# NLP
NLP_BOOT_MODE=service
NLP_VALIDATE_DB_ON_STARTUP=true

# UI
NEXT_PUBLIC_API_URL=http://localhost:3001
SAQR_UI_API_BASE=http://localhost:3001
SAQR_UI_AUTH_ENABLED=true
SAQR_UI_TOKEN_STORAGE_KEY=saqr_api_bearer_token
SAQR_UI_RUNTIME_PROFILE=delivery-handoff
SAQR_UI_RUNTIME_CONFIG=apps/shield-ui/runtime-config.production.js
