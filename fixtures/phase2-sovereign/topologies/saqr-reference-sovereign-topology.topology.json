      "sharedComponents": [
        "shield-ui",
        "api"
      ],
      "isolatedComponents": [
        "workflow-engine",
        "sentinel-scrapers",
        "cv-watchman",
        "nlp-interpreter",
        "evidence-vault"
      ],
      "externalDependencies": [
        "postgres",
        "kafka",
        "identity-provider",
        "vms-gateway",
        "ingress-gateway"
      ]
    },
    {
      "topologyKey": "client-on-premises",
      "pattern": "on_premises",
      "name": "Client On-Premises",
