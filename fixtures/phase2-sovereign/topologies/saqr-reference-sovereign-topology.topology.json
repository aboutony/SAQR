      "sharedComponents": [
        "shield-ui",
        "api",
        "workflow-engine"
      ],
      "isolatedComponents": [
        "sentinel-scrapers",
        "cv-watchman",
        "nlp-interpreter",
        "evidence-vault"
      ],
      "externalDependencies": [
        "postgres",
        "kafka",
