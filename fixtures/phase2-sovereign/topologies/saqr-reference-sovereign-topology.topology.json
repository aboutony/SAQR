  "componentPlacements": [
    {
      "componentKey": "shield-ui",
      "runtimeClass": "stateless",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "Presentation layer stays shared within the active topology boundary."
    },
    {
      "componentKey": "api",
      "runtimeClass": "stateless",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "API may scale horizontally inside the topology boundary."
    },
    {
      "componentKey": "workflow-engine",
      "runtimeClass": "control_plane",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "Workflow control plane can remain shared within an approved topology boundary."
    },
    {
      "componentKey": "sentinel-scrapers",
      "runtimeClass": "worker",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "Scraper partitioning is topology-sensitive and may be isolated by country or cluster."
    },
    {
      "componentKey": "cv-watchman",
      "runtimeClass": "worker",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "Camera and VMS proximity can require topology-local isolation."
    },
    {
      "componentKey": "nlp-interpreter",
      "runtimeClass": "worker",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "NLP processing can remain shared or isolated depending on the topology boundary."
    },
    {
      "componentKey": "evidence-vault",
      "runtimeClass": "stateful",
      "defaultPlacement": "shared_within_topology",
      "allowedPatterns": [
        "single_tenant",
        "per_country",
        "per_cluster",
        "on_premises"
      ],
      "notes": "Evidence handling may need the strictest local isolation inside multi-country or multi-cluster patterns."
    }
  ]
