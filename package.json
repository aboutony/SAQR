{
  "name": "saqr-phase1-toolchain",
  "private": true,
  "scripts": {
    "phase1:bootstrap": "node tools/ci/bootstrap-workspace.js",
    "phase1:handoff:verify": "node tools/ci/verify-phase1-handoff-package.js",
    "phase1:quality": "node tools/ci/run-phase1-quality-gates.js",
    "phase1:quality:ci": "node tools/ci/run-phase1-quality-gates.js --ci",
    "phase1:release:verify": "node tools/ci/run-phase1-release-readiness.js",
    "phase2:acceptance": "node tools/phase2-acceptance/run-phase2-acceptance.js --scenario all --json",
    "phase2:acceptance:test": "node --test tools/phase2-acceptance/harness.test.js",
    "phase2:handoff:verify": "node tools/ci/verify-phase2-handoff-package.js",
    "phase2:quality": "node tools/ci/run-phase2-quality-gates.js",
    "phase2:quality:ci": "node tools/ci/run-phase2-quality-gates.js --ci",
    "phase2:entity:isolation:validate": "node tools/phase2-entity/validate-entity-isolation.js",
    "phase2:entity:reporting:validate": "node tools/phase2-entity/validate-entity-reporting.js",
    "phase2:entity:rollup:validate": "node tools/phase2-entity/validate-entity-rollup.js",
    "phase2:entity:validate": "node tools/phase2-entity/validate-entity-hierarchy.js",
    "phase2:entity:scope:validate": "node tools/phase2-entity/validate-entity-scoping.js",
    "phase2:entity:test": "node --test shared/entity-hierarchy.test.js shared/entity-scoping.test.js shared/entity-isolation.test.js shared/entity-rollup.test.js shared/entity-reporting.test.js",
    "phase2:sovereign:packaging:test": "node --test shared/sovereign-packaging.test.js",
    "phase2:sovereign:packaging:validate": "node tools/phase2-sovereign/validate-sovereign-packaging.js",
    "phase2:sovereign:policy:test": "node --test shared/sovereign-policy.test.js",
    "phase2:sovereign:policy:validate": "node tools/phase2-sovereign/validate-sovereign-policy.js",
    "phase2:sovereign:validate": "node tools/phase2-sovereign/validate-sovereign-topology.js",
    "phase2:sovereign:test": "node --test shared/sovereign-topology.test.js",
    "phase2:workflow:validate": "node tools/phase2-workflow/validate-workflow-definition.js",
    "phase2:workflow:test": "node --test tools/phase2-workflow/validator.test.js",
    "phase2:workflow:engine:test": "npm --prefix services/workflow-engine test"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
